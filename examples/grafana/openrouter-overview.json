{
  "annotations": {
    "list": []
  },
  "description": "OpenRouter model pricing, uptime, throughput, and latency metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Scrape Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "openrouter_models_scraped",
          "legendFormat": "Models"
        },
        {
          "expr": "openrouter_endpoints_scraped",
          "legendFormat": "Endpoints"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Scrape Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "openrouter_scrape_duration_seconds",
          "legendFormat": "Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "Scrape Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "openrouter_scrape_errors_total",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Last Scrape",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "time() - openrouter_scrape_timestamp_seconds",
          "legendFormat": "Age"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "title": "Top 10 Most Expensive Models (Prompt)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "topk(10, openrouter_model_prompt_price_dollars_per_million_tokens)",
          "legendFormat": "{{model_id}} ({{provider_name}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Top 10 Most Expensive Models (Completion)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "topk(10, openrouter_model_completion_price_dollars_per_million_tokens)",
          "legendFormat": "{{model_id}} ({{provider_name}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Prompt Price Distribution",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "openrouter_model_prompt_price_dollars_per_million_tokens",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "$/M tokens" },
              { "id": "decimals", "value": 4 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "model_id": "Model",
              "provider_name": "Provider",
              "quantization": "Quantization",
              "tag": "Tag",
              "Value": "Prompt Price"
            }
          }
        }
      ]
    },
    {
      "title": "Completion Price Distribution",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "openrouter_model_completion_price_dollars_per_million_tokens",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "$/M tokens" },
              { "id": "decimals", "value": 4 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "model_id": "Model",
              "provider_name": "Provider",
              "quantization": "Quantization",
              "tag": "Tag",
              "Value": "Completion Price"
            }
          }
        }
      ]
    },
    {
      "title": "Cache Read Price vs Prompt Price",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "openrouter_model_prompt_price_dollars_per_million_tokens > 0",
          "legendFormat": "{{model_id}} prompt",
          "instant": true
        },
        {
          "expr": "openrouter_model_input_cache_read_price_dollars_per_million_tokens > 0",
          "legendFormat": "{{model_id}} cache",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Endpoint Uptime (5m / 30m / 1d)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_5m * on(model_id, provider_name, tag, quantization) group_left() openrouter_model_info",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_30m",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_1d",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Uptime 5m" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 90 },
                { "color": "green", "value": 99 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Uptime 30m" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Uptime 1d" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "model_name": true, "context_length": true, "modality": true, "tokenizer": true, "input_modalities": true, "output_modalities": true }
          }
        }
      ]
    },
    {
      "title": "Throughput by Model (tokens/s)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "openrouter_endpoint_throughput_tokens_per_second{quantile=\"p50\"}",
          "legendFormat": "{{model_id}} ({{provider_name}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Latency by Model (ms)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "openrouter_endpoint_latency_milliseconds{quantile=\"p50\"}",
          "legendFormat": "{{model_id}} ({{provider_name}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Latency Percentiles per Model",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "targets": [
        {
          "expr": "openrouter_endpoint_latency_milliseconds{quantile=\"p50\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{quantile=\"p75\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{quantile=\"p90\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{quantile=\"p99\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "p50 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "p75 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "p90 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #D" },
            "properties": [
              { "id": "displayName", "value": "p99 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "quantile": true }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 40,
  "tags": ["openrouter", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "model_id",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openrouter_model_info, model_id)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider_name",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openrouter_model_info{model_id=~\"$model_id\"}, provider_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenRouter Exporter",
  "uid": "openrouter-exporter",
  "version": 1
}
