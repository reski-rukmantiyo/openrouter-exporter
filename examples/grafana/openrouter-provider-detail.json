{
  "annotations": {
    "list": []
  },
  "description": "OpenRouter provider-specific detail: pricing, uptime, throughput, and latency per endpoint",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Endpoints",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\"})",
          "legendFormat": "Endpoints"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Unique Models",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "count(count by (model_id) (openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\"}))",
          "legendFormat": "Models"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Avg Uptime (1d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "avg(openrouter_endpoint_uptime_percentage_last_1d{provider_name=\"$provider_name\", model_id=~\"$model_id\"})",
          "legendFormat": "Avg Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Scrape Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "time() - openrouter_scrape_timestamp_seconds",
          "legendFormat": "Age"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "title": "Input & Output Price by Endpoint",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_model_output_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "provider_name": true, "tag": true },
            "renameByName": {
              "Value #A": "Input",
              "Value #B": "Output"
            }
          }
        }
      ]
    },
    {
      "title": "Cache Read vs Input Price",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"} > 0",
          "legendFormat": "{{model_id}} input",
          "instant": true
        },
        {
          "expr": "openrouter_model_input_cache_read_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"} > 0",
          "legendFormat": "{{model_id}} cache",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Pricing Table",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_model_output_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_model_input_cache_read_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Input $/M" },
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "$/M tokens" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Output $/M" },
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "$/M tokens" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Cache Read $/M" },
              { "id": "custom.align", "value": "right" },
              { "id": "unit", "value": "$/M tokens" },
              { "id": "decimals", "value": 4 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Input $/M" }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "provider_name": true },
            "renameByName": {
              "model_id": "Model",
              "quantization": "Quantization",
              "tag": "Tag"
            }
          }
        }
      ]
    },
    {
      "title": "Uptime by Endpoint (5m / 30m / 1d)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_5m{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_30m{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_1d{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Uptime 5m" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 90 },
                { "color": "green", "value": 99 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Uptime 30m" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 90 },
                { "color": "green", "value": 99 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Uptime 1d" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              { "id": "thresholds", "value": { "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 90 },
                { "color": "green", "value": 99 }
              ] } }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "provider_name": true }
          }
        }
      ]
    },
    {
      "title": "Uptime by Endpoint (Bar Chart)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_5m{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "legendFormat": "{{model_id}} {{quantization}} 5m",
          "instant": true
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_30m{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "legendFormat": "{{model_id}} {{quantization}} 30m",
          "instant": true
        },
        {
          "expr": "openrouter_endpoint_uptime_percentage_last_1d{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "legendFormat": "{{model_id}} {{quantization}} 1d",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Throughput by Endpoint (tokens/s)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [
        {
          "expr": "openrouter_endpoint_throughput_tokens_per_second{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=~\"$quantile\"}",
          "legendFormat": "{{model_id}} {{quantization}} {{quantile}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Latency by Endpoint (ms)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [
        {
          "expr": "openrouter_endpoint_latency_milliseconds{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=~\"$quantile\"}",
          "legendFormat": "{{model_id}} {{quantization}} {{quantile}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    },
    {
      "title": "Latency Percentiles per Endpoint",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 46 },
      "targets": [
        {
          "expr": "openrouter_endpoint_latency_milliseconds{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=\"p50\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=\"p75\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=\"p90\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        },
        {
          "expr": "openrouter_endpoint_latency_milliseconds{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\", quantile=\"p99\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "p50 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "p75 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "p90 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #D" },
            "properties": [
              { "id": "displayName", "value": "p99 (ms)" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "quantile": true, "provider_name": true }
          }
        }
      ]
    },
    {
      "title": "Price Comparison: This Provider vs All Providers (same models)",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 54 },
      "targets": [
        {
          "expr": "openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\", quantization=~\"$quantization\"}",
          "legendFormat": "$provider_name {{model_id}} input",
          "instant": true
        },
        {
          "expr": "openrouter_model_input_price_dollars_per_million_tokens{provider_name!=\"$provider_name\", model_id=~\"$model_id\"}",
          "legendFormat": "{{provider_name}} {{model_id}} input",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "$/M tokens",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stacking": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 40,
  "tags": ["openrouter", "prometheus", "provider"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "provider_name",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openrouter_model_input_price_dollars_per_million_tokens, provider_name)",
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "DekaLLM",
          "value": "DekaLLM"
        }
      },
      {
        "name": "model_id",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\"}, model_id)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "quantization",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(openrouter_model_input_price_dollars_per_million_tokens{provider_name=\"$provider_name\", model_id=~\"$model_id\"}, quantization)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "quantile",
        "type": "custom",
        "query": "p50,p75,p90,p99",
        "includeAll": true,
        "allValue": "p50",
        "multi": true,
        "current": {
          "selected": true,
          "text": "p50",
          "value": "p50"
        }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OpenRouter Provider Detail",
  "uid": "openrouter-provider-detail",
  "version": 1
}
