# Optional: set your OpenRouter API key to enable throughput/latency metrics
OPENROUTER_API_KEY=

# Optional: comma-separated list of model slugs to scrape activity for
OPENROUTER_ACTIVITY_MODELS=moonshotai/kimi-k2.6,nvidia/nemotron-3-super-120b-a12b,google/gemma-4-26b-a4b-it,z-ai/glm-4.7,mistralai/mistral-nemo

# Required for activity scraping: your OpenRouter __session cookie value
OPENROUTER_ACTIVITY_SESSION_COOKIE=

# Optional: how often to refresh activity data (default: 15m)
OPENROUTER_ACTIVITY_SCRAPE_INTERVAL=15m
